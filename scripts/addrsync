#!/system/bin/sh

# ==============================================================================
# [ Flux Address Sync Controller ]
# Description: Lifecycle management for addrsyncd (start, stop, resync, cleanup).
# ==============================================================================

set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

_script_path="${0}"
case "${_script_path}" in
/*) ;;
*) _script_path="${PWD}/${_script_path}" ;;
esac
readonly SCRIPT_DIR="${_script_path%/*}"

. "${SCRIPT_DIR}/lib"
. "${SCRIPT_DIR}/log"

readonly LOG_COMPONENT="ASyn"

# Best-effort postmortem on stage failure. See scripts/lib:dump_tombstone.
# REF: docs/p4-kernel-features-and-forensics.md section P4b.
trap 'dump_tombstone addrsync "$BASH_COMMAND failed (rc=$?)"' ERR

# ==============================================================================
# [ Daemon Process Management ]
# ==============================================================================

_start_daemon() {
    if "${ADDRSYNCD_BIN}" -c "${ADDRSYNCD_CONF_FILE}" -d "${RUN_DIR}" status >/dev/null 2>&1; then
        log_info "addrsyncd already running"
        return 0
    fi

    "${ADDRSYNCD_BIN}" -c "${ADDRSYNCD_CONF_FILE}" -d "${RUN_DIR}" run --daemon >/dev/null 2>&1
}

_wait_for_ready() {
    "${ADDRSYNCD_BIN}" -c "${ADDRSYNCD_CONF_FILE}" -d "${RUN_DIR}" status >/dev/null 2>&1
}

_stop_daemon() {
    "${ADDRSYNCD_BIN}" -c "${ADDRSYNCD_CONF_FILE}" -d "${RUN_DIR}" stop >/dev/null 2>&1 || true
    rm -f "${ADDRSYNCD_PID_FILE}" 2>/dev/null || true
    return 0
}

# ==============================================================================
# [ Service Control ]
# ==============================================================================

start_addrsync() {
    run -v "Start addrsyncd" _start_daemon || return $?
    run -v "addrsync startup" _wait_for_ready || return $?
}

stop_addrsync() {
    run -v "Stop addrsyncd" _stop_daemon || true
}

resync_addrsync() {
    "${ADDRSYNCD_BIN}" \
        -c "${ADDRSYNCD_CONF_FILE}" \
        -d "${RUN_DIR}" \
        resync >/dev/null 2>&1
}

status_addrsync() {
    "${ADDRSYNCD_BIN}" \
        -c "${ADDRSYNCD_CONF_FILE}" \
        -d "${RUN_DIR}" \
        status 2>&1
}

cleanup_addrsync() {
    "${ADDRSYNCD_BIN}" \
        -c "${ADDRSYNCD_CONF_FILE}" \
        -d "${RUN_DIR}" \
        cleanup --mode dump >/dev/null 2>&1
}

main() {
    local action="${1:-}"

    case "${action}" in
    start)
        start_addrsync
        ;;
    stop)
        stop_addrsync
        ;;
    resync)
        resync_addrsync
        ;;
    status)
        status_addrsync
        ;;
    cleanup)
        cleanup_addrsync
        ;;
    *)
        echo "Usage: $0 {start|stop|resync|status|cleanup}"
        exit 1
        ;;
    esac
}

main "$@"
