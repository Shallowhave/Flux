# ==============================================================================
# [ Flux Rules Orchestrator ]
# Description: Extreme Performance iptables rule generation and Jump Tree logic.
# ==============================================================================

# ==============================================================================
# [ Network & Routing Constants ]
# ==============================================================================

# Chain names for Proxy and Bypass logic. BYP_Z* zone chains are
# appended dynamically by _orchestrate based on which zones the
# built-in + user bypass lists actually populate, so empty zones
# do not consume chain slots or clutter `iptables -L` output.
readonly PROXY_CHAINS="PROXY_PREROUTING PROXY_OUTPUT BYPASS_IP APP_CHAIN ACTION_PROXY_PRE ACTION_PROXY_OUT ACTION_BYPASS"

# IP Bypasses for Android (Carrier-Safe + RFC 1918/6890/4193)
readonly BYPASS_IPv4_LIST="0.0.0.0/8 10.0.0.0/8 100.0.0.0/8 127.0.0.0/8 169.254.0.0/16 172.16.0.0/12 192.0.0.0/24 192.0.2.0/24 192.88.99.0/24 192.168.0.0/16 198.51.100.0/24 203.0.113.0/24 224.0.0.0/4 240.0.0.0/4 255.255.255.255/32"
readonly BYPASS_IPv6_LIST="::/128 ::1/128 ::ffff:0:0/96 100::/64 64:ff9b::/96 2001::/32 2001:10::/28 2001:20::/28 2001:db8::/32 2002::/16 fe80::/10 ff00::/8"

# Hotspot IP Ranges
readonly HOTSPOT_V4_RANGE="192.168.43.0/24"
readonly HOTSPOT_V6_RANGE="fe80::/10"

# ==============================================================================
# [ Jump Tree Algorithm ]
# ==============================================================================
# Problem: Linear subnet matching (O(n)) is inefficient for large lists.
# Solution: Partition subnets into 16 zones by first octet/nibble, achieving
#           O(1) zone selection + O(n/16) average zone lookup.
#
# IPv4 Zones: Based on first octet divided by 16 (e.g., 10.x.x.x → zone 0)
# IPv6 Zones: Based on first hex nibble (e.g., 2001:: → zone 2)
#
# Always enabled for stable O(1) zone routing.
_read_bypass_user_list() {
    local file="${1}"
    local family="${2}"
    [ -r "${file}" ] || return 0

    local line stripped
    while IFS= read -r line || [ -n "${line}" ]; do
        stripped="${line#"${line%%[![:space:]]*}"}"
        case "${stripped}" in
            ''|'#'*) continue ;;
        esac
        if [ "${family}" = "6" ]; then
            case "${stripped}" in
                *:*) ;;
                *) log_warn "bypass.v6.list: skipping invalid CIDR '${stripped}'"; continue ;;
            esac
            case "${stripped}" in
                *[!0-9a-fA-F:./]*) log_warn "bypass.v6.list: skipping invalid CIDR '${stripped}'"; continue ;;
            esac
        else
            case "${stripped}" in
                *.*) ;;
                *) log_warn "bypass.v4.list: skipping invalid CIDR '${stripped}'"; continue ;;
            esac
            case "${stripped}" in
                *[!0-9./]*) log_warn "bypass.v4.list: skipping invalid CIDR '${stripped}'"; continue ;;
            esac
        fi
        printf '%s ' "${stripped}"
    done <"${file}"
}

_build_bypass_ip_rules() {
    local suffix="${1}"
    local family="${2}"
    local subnets="${3}"

    local chain="BYPASS_IP${suffix}"

    awk -v subnets="${subnets}" -v chain="${chain}" -v family="${family}" -v suffix="${suffix}" '
    BEGIN {
        for (i = 0; i < 16; i++) zones[i] = 0

        n = split(subnets, nets, /[[:space:]]+/)
        for (j = 1; j <= n; j++) {
            net = nets[j]
            if (net == "" || net == "::") continue

            if (family == "6") {
                clean_ip = tolower(net)
                sub(/^[:]+/, "", clean_ip)
                if (clean_ip == "") {
                    zone = 0
                } else {
                    zone = index("0123456789abcdef", substr(clean_ip, 1, 1)) - 1
                }
            } else {
                split(net, o, ".")
                zone = int(o[1] / 16)
            }

            if (zone < 0 || zone > 15) zone = 0
            printf "-A BYP_Z%d%s -d %s -j ACTION_BYPASS%s\n", zone, suffix, net, suffix
            zones[zone] = 1
        }

        for (i = 0; i < 16; i++) {
            if (!zones[i]) continue
            if (family == "6") {
                printf "-A %s -d %x000::/4 -j BYP_Z%d%s\n", chain, i, i, suffix
            } else {
                printf "-A %s -d %d.0.0.0/4 -j BYP_Z%d%s\n", chain, i * 16, i, suffix
            }
        }
    }'
}

# Compute the set of zone indices (0..15) that contain at least one
# CIDR from the supplied merged bypass list. Returned as a space-
# separated string suitable for shell iteration. Same zone math as
# _build_bypass_ip_rules so the two stay in agreement.
_compute_bypass_zones() {
    local family="${1}"
    local subnets="${2}"

    awk -v subnets="${subnets}" -v family="${family}" '
    BEGIN {
        n = split(subnets, nets, /[[:space:]]+/)
        for (j = 1; j <= n; j++) {
            net = nets[j]
            if (net == "" || net == "::") continue

            if (family == "6") {
                clean_ip = tolower(net)
                sub(/^[:]+/, "", clean_ip)
                if (clean_ip == "") {
                    zone = 0
                } else {
                    zone = index("0123456789abcdef", substr(clean_ip, 1, 1)) - 1
                }
            } else {
                split(net, o, ".")
                zone = int(o[1] / 16)
            }

            if (zone < 0 || zone > 15) zone = 0
            zones[zone] = 1
        }

        out = ""
        for (i = 0; i < 16; i++) if (zones[i]) out = out " " i
        sub(/^ /, "", out)
        print out
    }'
}

# ==============================================================================
# [ Application Rules ]
# ==============================================================================

_build_app_rules() {
    local suffix="${1}"
    local mode="${2}"
    local action_proxy="ACTION_PROXY_OUT${suffix}"

    if [ "${KFEAT_OWNER}" = "1" ]; then
        printf -- '-A APP_CHAIN%s -m owner --uid-owner %s --gid-owner %s -j ACTION_BYPASS%s\n' "${suffix}" "${CORE_USER}" "${CORE_GROUP}" "${suffix}"
    elif [ "${KFEAT_MARK}" = "1" ] && [ -n "${ROUTING_MARK}" ]; then
        printf -- '-A APP_CHAIN%s -m mark --mark %s -j ACTION_BYPASS%s\n' "${suffix}" "${ROUTING_MARK}" "${suffix}"
    fi

    if [ "${mode}" = "0" ]; then
        printf -- '-A APP_CHAIN%s -j RETURN\n' "${suffix}"
        return 0
    fi

    local pkgs="${APP_LIST}"
    [ -z "${pkgs}" ] && return 0

    local target
    if [ "${mode}" = "1" ]; then
        target="ACTION_BYPASS${suffix}"
    else
        target="${action_proxy}"
    fi

    awk -v app_list="${pkgs}" -v suffix="${suffix}" -v target="${target}" \
        -v scope="${APP_USER_SCOPE}" -v user_list="${APP_USER_LIST}" '
    BEGIN {
        if (app_list == "") exit
        n = split(app_list, arr, /[[:space:]]+/)
        for (i = 1; i <= n; i++) if (arr[i] != "") targets[arr[i]] = 1

        if (scope == "all") {
            users[0] = 1
            for (u = 1; u <= 99; u++) users[u] = 1
        } else if (scope == "list") {
            n_users = split(user_list, user_arr, /[[:space:]]+/)
            for (u = 1; u <= n_users; u++) if (user_arr[u] != "") users[user_arr[u] + 0] = 1
        } else {
            users[0] = 1
        }
    }
    {
        pkg=$1; uid=$2
        if (pkg in targets) {
            app_id = uid % 100000
            for (user_id in users) {
                derived_uid = user_id * 100000 + app_id
                printf "-A APP_CHAIN%s -m owner --uid-owner %s -j %s\n", suffix, derived_uid, target
            }
        }
    }
    ' "${PACKAGES_LIST}"

    if [ "${mode}" = "1" ]; then
        printf -- '-A APP_CHAIN%s -j %s\n' "${suffix}" "${action_proxy}"
    else
        printf -- '-A APP_CHAIN%s -j ACCEPT\n' "${suffix}"
    fi
}

# ==============================================================================
# [ Chain Builders ]
# ==============================================================================
# Build action chains (Context-Aware Proxy Actions)
_build_action_chain() {
    local name="${1}"
    local mark="${2}"
    local full_mark="${3}"
    local tproxy="${4}"

    if [ "${KFEAT_CONNTRACK}" = "1" ] && [ "${KFEAT_MARK}" = "1" ]; then
        printf -- '-A %s -j CONNMARK --set-xmark %s\n' "${name}" "${full_mark}"
        printf -- '-A %s -j MARK --set-xmark %s\n' "${name}" "${full_mark}"
    fi

    if [ "${tproxy}" = "1" ]; then
        printf -- '-A %s -p tcp -j TPROXY --on-port %s --tproxy-mark %s\n' "${name}" "${PROXY_PORT}" "${full_mark}"
        printf -- '-A %s -p udp -j TPROXY --on-port %s --tproxy-mark %s\n' "${name}" "${PROXY_PORT}" "${full_mark}"
    fi
    printf -- '-A %s -j ACCEPT\n' "${name}"
}

_build_divert_rules() {
    local suffix="${1}"
    local mark="${2}"
    local full_mark="${3}"

    [ "${PERFORMANCE_MODE}" = "1" ] || return 0
    [ "${KFEAT_SOCKET_TCP:-${KFEAT_SOCKET}}" = "1" ] || return 0
    [ "${KFEAT_MARK}" = "1" ] || return 0

    printf -- '-A DIVERT%s -j MARK --set-xmark %s\n' "${suffix}" "${full_mark}"
    printf -- '-A DIVERT%s -j ACCEPT\n' "${suffix}"
    printf -- '-A PROXY_PREROUTING%s -p tcp -m socket --transparent -j DIVERT%s\n' "${suffix}" "${suffix}"
    [ "${KFEAT_SOCKET_UDP:-0}" = "1" ] && printf -- '-A PROXY_PREROUTING%s -p udp -m socket --transparent -j DIVERT%s\n' "${suffix}" "${suffix}"
}

# Build the iptables chain structure for a specific action
_build_ipt_chains() {
    local suffix="${1}"
    local action="${2}"
    local list="${3}"
    local chain

    for chain in ${list}; do
        case "${action}" in
        create) printf -- ':%s%s - [0:0]\n' "${chain}" "${suffix}" ;;
        flush) printf -- '-F %s%s\n' "${chain}" "${suffix}" ;;
        delete) printf -- '-X %s%s\n' "${chain}" "${suffix}" ;;
        esac
    done
}

# Build the fast-path rules (Stateful & High-Frequency Recovery)
_build_fast_path_rules() {
    local suffix="${1}"
    local mark="${2}"
    local proxy_mark="${3}"
    local bypass_mark="${4}"

    [ "${KFEAT_CONNTRACK}" = "1" ] && {
        printf -- '-A PROXY_PREROUTING%s -m conntrack --ctdir REPLY -j ACCEPT\n' "${suffix}"
    }

    [ "${KFEAT_MARK}" = "1" ] && [ "${KFEAT_CONNTRACK}" = "1" ] && {
        cat <<EOF
-A PROXY_PREROUTING${suffix} -m connmark --mark ${bypass_mark} -j ACCEPT
-A PROXY_OUTPUT${suffix} -m connmark --mark ${bypass_mark} -j ACCEPT
-A PROXY_PREROUTING${suffix} -m connmark --mark ${proxy_mark} -p tcp -j TPROXY --on-port ${PROXY_PORT} --tproxy-mark ${proxy_mark}
-A PROXY_PREROUTING${suffix} -m connmark --mark ${proxy_mark} -p udp -j TPROXY --on-port ${PROXY_PORT} --tproxy-mark ${proxy_mark}
-A PROXY_PREROUTING${suffix} -m connmark --mark ${proxy_mark} -j ACCEPT
-A PROXY_OUTPUT${suffix} -m connmark --mark ${proxy_mark} -j MARK --set-xmark ${proxy_mark}
-A PROXY_OUTPUT${suffix} -m connmark --mark ${proxy_mark} -j ACCEPT
EOF
    }
}

# Build chain rules (chain, action, flag, ex_list, is_pre, app)
_build_chain_rules() {
    local chain="${1}"
    local action="${2}"
    local flag="${3}"
    local ex_list="${4}"
    local is_pre="${5}"
    local app="${6}"

    # Arguments passed via awk variables for safety
    awk -v chain="${chain}" -v action="${action}" -v flag="${flag}" -v ex_list="${ex_list}" \
        -v is_pre="${is_pre}" -v app="${app}" \
        -v m_if="${MOBILE_INTERFACE}" -v m_en="${PROXY_MOBILE}" \
        -v w_if="${WIFI_INTERFACE}" -v w_en="${PROXY_WIFI}" \
        -v h_if="${HOTSPOT_INTERFACE}" -v h_en="${PROXY_HOTSPOT}" \
        -v u_if="${USB_INTERFACE}" -v u_en="${PROXY_USB}" '
    BEGIN {
        suffix = chain; gsub(/.*_/, "", suffix); gsub(/PREROUTING|OUTPUT/, "", suffix)
        bypass = "ACTION_BYPASS" suffix

        printf "-A %s -j BYPASS_IP%s\n", chain, suffix
        if (is_pre == "1") printf "-A %s -i lo -j ACCEPT\n", chain

        split(ex_list, ex_arr, " ")
        ex_tgt = (is_pre == "1") ? "ACCEPT" : bypass
        for (i in ex_arr) if (ex_arr[i]) printf "-A %s %s %s -j %s\n", chain, flag, ex_arr[i], ex_tgt

        n = split(m_if" "w_if" "h_if" "u_if, ifs, " ")
        split(m_en" "w_en" "h_en" "u_en, ens, " ")
        for (i = 1; i <= n; i++) {
            if (!ifs[i]) continue
            if (is_pre == "1" && ens[i] == "1") printf "-A %s %s %s -j %s\n", chain, flag, ifs[i], action
            if (is_pre != "1" && ens[i] != "1") printf "-A %s %s %s -j %s\n", chain, flag, ifs[i], bypass
        }

        if (is_pre == "1") {
            printf "-A %s -j ACCEPT\n", chain
        } else {
            if (app != "0") printf "-A %s -j APP_CHAIN%s\n", chain, suffix
            printf "-A %s -j %s\n", chain, action
        }
    }'
}

# ==============================================================================
# [ Special Rules ]
# ==============================================================================

_build_loopback_rules() {
    local family="${1}"
    local action="${2}"

    [ "${KFEAT_OWNER}" = "0" ] && return 0

    local addr
    if [ "${family}" = "6" ]; then
        addr="::1"
    else
        addr="127.0.0.1"
    fi

    cat <<EOF
*filter
${action} OUTPUT -d ${addr} -p tcp -m owner --uid-owner ${CORE_USER} --gid-owner ${CORE_GROUP} -m tcp --dport ${PROXY_PORT} -j REJECT
COMMIT
EOF
}

_build_fakeip_rules() {
    local family="${1}"
    local action="${2}"

    { [ "${family}" = "6" ] && [ "${KFEAT_IPV6_NAT}" = "0" ]; } && return 0

    local range
    local addr
    local proto

    if [ "${family}" = "6" ]; then
        range="${FAKEIP_V6_RANGE}"
        addr="::1"
        proto="ipv6-icmp"
    else
        range="${FAKEIP_V4_RANGE}"
        addr="127.0.0.1"
        proto="icmp"
    fi

    cat <<EOF
*nat
${action} OUTPUT -d ${range} -p ${proto} -j DNAT --to-destination ${addr}
${action} PREROUTING -d ${range} -p ${proto} -j DNAT --to-destination ${addr}
COMMIT
EOF
}

_build_mss_clamp_rules() {
    local action="${1}"
    [ "${MSS_CLAMP_ENABLE}" = "1" ] || return 0
    cat <<EOF
*mangle
${action} POSTROUTING -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
COMMIT
EOF
}

# ==============================================================================
# [ Orchestrator ]
# ==============================================================================
# Unified orchestrator (-A: apply, -D: cleanup)
_orchestrate() {
    local action="${1}"
    local family="${2}"
    local suffix=""
    [ "${family}" = "6" ] && suffix="6"

    local mark
    if [ "${family}" = "6" ]; then
        mark="${IPV6_MARK}"
    else
        mark="${IPV4_MARK}"
    fi

    local proxy_mark="${mark}/${MARK_MASK}"
    local bypass_mark="${BYPASS_MARK}/${MARK_MASK}"
    local app_mode="${APP_PROXY_MODE}"

    if [ "${app_mode}" != "0" ] && [ "${KFEAT_OWNER}" != "1" ]; then
        log_warn "APP_PROXY_MODE requires xt_owner, app filter disabled for IPv${family}"
        app_mode="0"
    fi

    # Resolve the merged bypass list once (built-in + optional user file)
    # so subsequent steps share one zone-occupancy computation.
    local user_file subnets
    if [ "${family}" = "6" ]; then
        user_file="${CONF_DIR}/bypass.v6.list"
        subnets="${BYPASS_IPv6_LIST}"
    else
        user_file="${CONF_DIR}/bypass.v4.list"
        subnets="${BYPASS_IPv4_LIST}"
    fi
    # User entries are additive only; built-ins are never removed
    # (e.g. dropping 127.0.0.0/8 would break loopback for local services).
    local user_subnets
    user_subnets="$(_read_bypass_user_list "${user_file}" "${family}")"
    [ -n "${user_subnets}" ] && subnets="${subnets} ${user_subnets}"

    local bypass_zones zone
    bypass_zones="$(_compute_bypass_zones "${family}" "${subnets}")"

    # Chain list: base + populated BYP_Z* + optional DIVERT. Empty zones
    # get no chain slot — fewer phantom chains, cleaner iptables -L output.
    local chains="${PROXY_CHAINS}"
    for zone in ${bypass_zones}; do
        chains="${chains} BYP_Z${zone}"
    done
    if [ "${PERFORMANCE_MODE}" = "1" ] && [ "${KFEAT_SOCKET_TCP:-${KFEAT_SOCKET}}" = "1" ] && [ "${KFEAT_MARK}" = "1" ]; then
        chains="${chains} DIVERT"
    fi

    printf -- '*mangle\n'

    if [ "${action}" = "-A" ]; then
        _build_ipt_chains "${suffix}" "create" "${chains}"

        # Define ACTION chains
        if [ "${KFEAT_CONNTRACK}" = "1" ] && [ "${KFEAT_MARK}" = "1" ]; then
            printf -- '-A ACTION_BYPASS%s -j CONNMARK --set-xmark %s\n' "${suffix}" "${bypass_mark}"
        fi
        printf -- '-A ACTION_BYPASS%s -j ACCEPT\n' "${suffix}"

        _build_action_chain "ACTION_PROXY_PRE${suffix}" "${mark}" "${proxy_mark}" 1
        _build_action_chain "ACTION_PROXY_OUT${suffix}" "${mark}" "${proxy_mark}" 0

        _build_bypass_ip_rules "${suffix}" "${family}" "${subnets}"
        [ "${app_mode}" != "0" ] && _build_app_rules "${suffix}" "${app_mode}"

        _build_divert_rules "${suffix}" "${mark}" "${proxy_mark}"
        _build_fast_path_rules "${suffix}" "${mark}" "${proxy_mark}" "${bypass_mark}"

        _build_chain_rules \
            "PROXY_PREROUTING${suffix}" "ACTION_PROXY_PRE${suffix}" \
            "-i" "${EXCLUDE_INTERFACES}" 1 "${app_mode}"
        _build_chain_rules \
            "PROXY_OUTPUT${suffix}" "ACTION_PROXY_OUT${suffix}" \
            "-o" "${EXCLUDE_INTERFACES}" 0 "${app_mode}"

        printf -- '-I PREROUTING -j PROXY_PREROUTING%s\n' "${suffix}"
        printf -- '-I OUTPUT -j PROXY_OUTPUT%s\n' "${suffix}"
    else
        printf -- '-D PREROUTING -j PROXY_PREROUTING%s\n' "${suffix}"
        printf -- '-D OUTPUT -j PROXY_OUTPUT%s\n' "${suffix}"

        _build_ipt_chains "${suffix}" "flush" "${chains}"
        _build_ipt_chains "${suffix}" "delete" "${chains}"
    fi

    printf 'COMMIT\n'
}

# ==============================================================================
# [ Public API ]
# ==============================================================================
# Unified rule generation API (action: -A/-D)
generate() {
    local action="${1}"
    local family="${2}"

    if [ "${PROXY_MODE}" = "tun" ]; then
        printf -- '*mangle\nCOMMIT\n'
        return 0
    fi

    _orchestrate "${action}" "${family}"
    _build_loopback_rules "${family}" "${action}"
    _build_fakeip_rules "${family}" "${action}"
    _build_mss_clamp_rules "${action}"
}
