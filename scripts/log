#!/system/bin/sh

# ==============================================================================
# [ Flux Logging System ]
# Description: Unified terminal logging, coloring, and Magisk status reporting.
# ==============================================================================

LOG_COMPONENT="${LOG_COMPONENT:-Name}"
LOG_LEVEL="${LOG_LEVEL:-3}"

# Detect if the current execution environment supports ANSI color codes
_is_terminal() {
    [ -t 2 ]
}

# ==============================================================================
# [ Log Level Configuration ]
# ==============================================================================
# 0: OFF
# 1: ERROR   - Critical failures requiring immediate attention
# 2: WARNING - Recoverable issues or unexpected states
# 3: INFO    - High-level progress markers (Default)
# 4: DEBUG   - Verbose execution tracing
# ==============================================================================

_LOG_LAST_SEC=-1
_LOG_LAST_TIME=""

_get_timestamp() {
    if [ -n "${EPOCHSECONDS:-}" ]; then
        echo "${EPOCHSECONDS}"
    else
        date +%s
    fi
}

_log() {
    local level="${1}"
    local level_num="${2}"
    local msg="${3}"
    [ "${LOG_LEVEL}" -lt "${level_num}" ] && return 0

    # Fast timestamping: cache formatted time by unix second in a shell-agnostic way.
    local now
    now=$(_get_timestamp)
    if [ "${now}" -ne "${_LOG_LAST_SEC}" ]; then
        _LOG_LAST_SEC="${now}"
        _LOG_LAST_TIME=$(date '+%m-%d %H:%M:%S')
    fi

    local log_line="[${_LOG_LAST_TIME}] [${level}] [${LOG_COMPONENT}] ${msg}"

    if _is_terminal; then
        # Color lookup: E=31(red), W=33(yellow), I=32(green), D=90(gray)
        local color
        case "${level}" in
        E) color=31 ;;
        W) color=33 ;;
        I) color=32 ;;
        D) color=90 ;;
        *) color=0 ;;
        esac
        printf '\033[%sm%s\033[0m\n' "${color}" "${log_line}" >&2
    else
        printf '%s\n' "${log_line}" >&2
    fi
}

# Professional ASCII/ANSI banner for console output highlighting
log_banner() {
    local msg=" ${1} "
    local width=50
    local sym="="
    local len=${#msg}
    local side=$(((width - len) / 2))
    [ "${side}" -lt 0 ] && side=0

    local pad
    pad=$(printf "%${side}s" "" | tr ' ' "${sym}")
    local banner="${pad}${msg}${pad}"
    [ "${#banner}" -lt "${width}" ] && banner="${banner}${sym}"

    if _is_terminal; then
        printf '\n\033[1;36m%s\033[0m\n' "${banner}" >&2
    else
        printf '\n%s\n' "${banner}" >&2
    fi
}

log_debug() { _log "D" 4 "${1}"; }
log_info() { _log "I" 3 "${1}"; }
log_warn() { _log "W" 2 "${1}"; }
log_error() { _log "E" 1 "${1}"; }

# ==============================================================================
# [ Magisk User Interface (module.prop) Management ]
# ==============================================================================
# Flux updates the Magisk module description in real-time to provide
# status feedback to the user via the Magisk/KSU app.
# Format: original_description\n🥰 [RUNNING] PID: xxx
# ==============================================================================

_L_STAT=""
sync_prop() {
    [ ! -f "${PROP_FILE}" ] && return 0

    # 1. Build status (Internal)
    local state="${1}"
    local emoji
    local pid=""

    case "${state}" in
    RUNNING) emoji='🥰' ;;
    STOPPED) emoji='😴' ;;
    FAILED) emoji='🤯' ;;
    *) emoji='🤔' ;;
    esac
    [ "${state}" = "RUNNING" ] && [ -f "${SING_BOX_PID_FILE}" ] && IFS= read -r pid <"${SING_BOX_PID_FILE}" || true

    local status="${emoji} [${state}]${pid:+ PID: ${pid}}"

    # 2. Skip if no change
    [ "${status}" = "${_L_STAT}" ] && return 0
    _L_STAT="${status}"

    # 3. Atomic write: avoid in-place sed escaping pitfalls.
    local tmp_prop
    tmp_prop=$(mktemp "${PROP_FILE}.XXXXXX") || return 0

    # Use awk for a single-pass extraction and replacement to minimize process fork overhead.
    if awk -v stat="${status}" '
        BEGIN { done=0 }
        $0 ~ /^description=/ {
            # Extract base description, strip previous status (\n...), and trim whitespace
            base = substr($0, index($0, "=") + 1)
            sub(/\\n.*/, "", base)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", base)
            if (base == "") base = "Flux Proxy Module"

            print "description=" base "\\n" stat
            done=1; next
        }
        { print }
        END { if (!done) print "description=Flux Proxy Module\\n" stat }
    ' "${PROP_FILE}" >"${tmp_prop}"; then
        mv -f "${tmp_prop}" "${PROP_FILE}" 2>/dev/null || rm -f "${tmp_prop}"
    else
        rm -f "${tmp_prop}"
    fi

    log_debug "Status: ${state}"
}
