#!/system/bin/sh

# ==============================================================================
# [ Flux CLI Control Plane ]
# Description: CLI-only service control, diagnostics, and rule preview.
# ==============================================================================

set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

_script_path="${0}"
case "${_script_path}" in
/*) ;;
*) _script_path="${PWD}/${_script_path}" ;;
esac
readonly SCRIPT_DIR="${_script_path%/*}"

. "${SCRIPT_DIR}/lib"
. "${SCRIPT_DIR}/log"

readonly LOG_COMPONENT="Ctl"

CONFIG_READY=0
load_config >/dev/null 2>&1 && CONFIG_READY=1 || true

# ==============================================================================
# [ Validation Commands ]
# REF: sing-box docs: https://sing-box.sagernet.org/configuration/
#      sing-box "check" subcommand validates config without running.
# REF: scripts/config:_validate_singbox_config exists, just expose it via CLI.
# ==============================================================================

validate_cmd() {
    local exit_code=0

    # Ensure config module functions are available (idempotent source).
    # load_config sources CONFIG_SCRIPT on cache-miss; if it took the cache path,
    # _process_settings is not yet defined. Source explicitly here.
    if ! command -v _process_settings >/dev/null 2>&1; then
        [ -f "${CONFIG_SCRIPT}" ] && . "${CONFIG_SCRIPT}"
    fi

    printf '=== Flux Configuration Validation ===\n\n'

    # 1. Check sing-box binary
    if [ ! -x "${SING_BOX_BIN}" ]; then
        printf '[sing-box] binary missing or not executable: %s\n' "${SING_BOX_BIN}"
        return 1
    fi

    # 2. Validate sing-box config.json
    # REF: sing-box check is standard; sing-box has no full config hot reload
    #      (no SIGHUP handler, no PUT /config). Only Clash API PUT /proxies/:name
    #      is hot-switchable. See analysis Section 3.3.
    printf '[sing-box config] '
    if [ ! -s "${CONFIG_FILE}" ]; then
        printf 'MISSING (no config.json found)\n'
        exit_code=1
    else
        local check_err
        if check_err=$("${SING_BOX_BIN}" check -c "${CONFIG_FILE}" -D "${RUN_DIR}" 2>&1); then
            printf 'OK\n'
        else
            printf 'FAILED\n'
            printf '%s\n' "${check_err}" | while IFS= read -r line; do
                printf '  >> %s\n' "${line}"
            done
            exit_code=1
        fi
    fi

    # 3. Validate settings.ini schema
    # REF: _process_settings is the awk schema-driven validator from scripts/config.
    printf '[settings schema] '
    if [ ! -s "${SETTINGS_FILE}" ]; then
        printf 'MISSING (no settings.ini found)\n'
        exit_code=1
    else
        local settings_tmp
        settings_tmp=$(mktemp "${RUN_DIR}/validate_settings.XXXXXX") || {
            printf 'ERROR (cannot create temp file)\n'
            exit_code=1
            return "${exit_code}"
        }
        if _process_settings >"${settings_tmp}" 2>/dev/null; then
            printf 'OK\n'
            rm -f "${settings_tmp}"
        else
            printf 'FAILED\n'
            # Show validation errors (they go to stderr from awk)
            _process_settings >/dev/null 2>&1 || true
            rm -f "${settings_tmp}"
            exit_code=1
        fi
    fi

    # 4. Report kernel features (from cache, without rebuilding)
    printf '\n[kernel features]\n'
    if [ -s "${CACHE_KERNEL_CAPS_FILE}" ]; then
        while IFS='=' read -r key val; do
            case "${key}" in
            KFEAT_*)
                if [ "${val}" = "1" ]; then
                    printf '  %-22s available\n' "${key#KFEAT_}"
                else
                    printf '  %-22s absent\n' "${key#KFEAT_}"
                fi
                ;;
            esac
        done <"${CACHE_KERNEL_CAPS_FILE}"
    else
        printf '  (no cached kernel features — run init or rebuild cache first)\n'
    fi

    printf '\n=== Validation %s ===\n' "$([ "${exit_code}" -eq 0 ] && printf 'PASSED' || printf 'FAILED')"
    return "${exit_code}"
}

_print_kv() {
    printf '%-22s %s\n' "${1}:" "${2}"
}

_pid_status() {
    local pid_file="${1}"
    local label="${2}"
    local match="${3}"
    local pid=""

    pid=$(read_pid_file "${pid_file}" "${label}" 2>/dev/null || true)
    if [ -n "${pid}" ] && pid_alive "${pid}" && pid_matches_cmd "${pid}" "${match}"; then
        printf 'running (pid=%s)\n' "${pid}"
    else
        printf 'stopped\n'
    fi
}

_service_state() {
    local state="unknown"
    if [ -f "${PROP_FILE}" ]; then
        state=$(awk -F'[][]' '/^description=.*\[[A-Z]+\]/ { print $2; found=1 } END { if (!found) print "unknown" }' "${PROP_FILE}" 2>/dev/null)
    fi
    printf '%s\n' "${state}"
}

status_cmd() {
    _print_kv "config" "$([ "${CONFIG_READY}" = "1" ] && printf ready || printf failed)"
    _print_kv "module" "$(_service_state)"
    [ "${CONFIG_READY}" = "1" ] && _print_kv "proxy mode" "${PROXY_MODE}"
    _print_kv "sing-box" "$(_pid_status "${SING_BOX_PID_FILE}" "sing-box" "${SING_BOX_BIN}")"
    if [ "${CONFIG_READY}" = "1" ]; then
        if [ "${PROXY_MODE}" = "tun" ]; then
            [ -d "/sys/class/net/${TUN_INTERFACE}" ] && _print_kv "tun interface" "up (${TUN_INTERFACE})" || _print_kv "tun interface" "missing (${TUN_INTERFACE})"
        elif is_port_listening "${PROXY_PORT}" >/dev/null 2>&1; then
            _print_kv "tproxy port" "listening (${PROXY_PORT})"
        else
            _print_kv "tproxy port" "not listening (${PROXY_PORT})"
        fi
    fi

    if [ -x "${ADDRSYNCD_BIN}" ] && [ -f "${ADDRSYNCD_CONF_FILE}" ]; then
        _print_kv "addrsyncd" "$("${ADDRSYNCD_BIN}" -c "${ADDRSYNCD_CONF_FILE}" -d "${RUN_DIR}" status 2>/dev/null || printf stopped)"
    else
        _print_kv "addrsyncd" "unavailable"
    fi

    [ -s "${ACTIVE_RUNTIME_FILE}" ] && _print_kv "active runtime" "${ACTIVE_RUNTIME_FILE}" || _print_kv "active runtime" "none"
}

_print_file_section() {
    local title="${1}"
    local file="${2}"

    printf '\n[%s]\n' "${title}"
    if [ -s "${file}" ]; then
        sed -n '1,160p' "${file}"
    else
        printf 'missing\n'
    fi
}

diagnose_cmd() {
    status_cmd

    _print_file_section "kernel capabilities" "${CACHE_KERNEL_CAPS_FILE}"
    _print_file_section "active runtime" "${ACTIVE_RUNTIME_FILE}"

    printf '\n[ip rule]\n'
    if command -v ip >/dev/null 2>&1; then
        ip rule show 2>/dev/null | grep -E "fwmark|${TABLE_ID}" || true
        ip -6 rule show 2>/dev/null | grep -E "fwmark|${TABLE_ID}" || true
    else
        printf 'ip command missing\n'
    fi

    printf '\n[iptables mangle chains]\n'
    if command -v iptables-save >/dev/null 2>&1; then
        iptables-save -t mangle 2>/dev/null | grep -E 'PROXY_|BYPASS_|BYP_Z|DIVERT|BLOCK_QUIC' || true
    else
        printf 'iptables-save missing\n'
    fi

    printf '\n[config check]\n'
    if [ -x "${SING_BOX_BIN}" ] && [ -s "${CONFIG_FILE}" ]; then
        "${SING_BOX_BIN}" check -c "${CONFIG_FILE}" -D "${RUN_DIR}" 2>&1 || true
    else
        printf 'sing-box binary or config missing\n'
    fi
}

_line_count() {
    local file="${1}"
    [ -s "${file}" ] || {
        printf '0'
        return 0
    }
    wc -l <"${file}" 2>/dev/null | tr -d ' '
}

rules_preview_cmd() {
    [ "${CONFIG_READY}" = "1" ] || {
        log_error "Config is not ready"
        return 1
    }

    sh "${INIT_SCRIPT}" cache >/dev/null

    printf '[rules]\n'
    _print_kv "backend" "${RULE_BACKEND}"
    _print_kv "bypass backend" "${BYPASS_SET_BACKEND}"
    _print_kv "proxy mode" "${PROXY_MODE}"
    _print_kv "mark mask" "${MARK_MASK}"
    _print_kv "performance mode" "${PERFORMANCE_MODE}"
    _print_kv "ipv4 apply lines" "$(_line_count "${CACHE_RULES_V4_FILE}")"
    _print_kv "ipv4 cleanup lines" "$(_line_count "${CACHE_CLEANUP_V4_FILE}")"
    if [ "${PROXY_IPV6}" = "1" ]; then
        _print_kv "ipv6 apply lines" "$(_line_count "${CACHE_RULES_V6_FILE}")"
        _print_kv "ipv6 cleanup lines" "$(_line_count "${CACHE_CLEANUP_V6_FILE}")"
    else
        _print_kv "ipv6" "disabled"
    fi

    printf '\n[routing]\n'
    if [ "${PROXY_MODE}" = "tun" ]; then
        printf 'sing-box tun interface %s %s mtu %s\n' "${TUN_INTERFACE}" "${TUN_INET4_ADDRESS}" "${TUN_MTU}"
    else
        printf 'addrsyncd pbr apply --family 4 --mark %s --mask %s --table %s --pref %s\n' "${IPV4_MARK}" "${MARK_MASK}" "${TABLE_ID}" "${TABLE_ID}"
        if [ "${PROXY_IPV6}" = "1" ]; then
            printf 'addrsyncd pbr apply --family 6 --mark %s --mask %s --table %s --pref %s\n' "${IPV6_MARK}" "${MARK_MASK}" "${TABLE_ID}" "${TABLE_ID}"
        fi
    fi
}

logs_cmd() {
    local file="${1:-${FLUX_LOG}}"
    if [ -f "${file}" ]; then
        tail -n 120 "${file}"
    else
        log_error "Log file missing: ${file}"
        return 1
    fi
}

main() {
    local action="${1:-status}"
    shift || true

    case "${action}" in
    start | stop)
        sh "${DISPATCHER_SCRIPT}" "${action}" "$@"
        ;;
    restart)
        sh "${DISPATCHER_SCRIPT}" restart "fluxctl"
        ;;
    status)
        status_cmd
        ;;
    diagnose)
        diagnose_cmd
        ;;
    rules-preview | preview)
        rules_preview_cmd
        ;;
    resync)
        sh "${ADDRSYNC_SCRIPT}" resync
        ;;
    logs)
        logs_cmd "$@"
        ;;
    validate)
        validate_cmd
        ;;
    *)
        echo "Usage: $0 {status|start|stop|restart|diagnose|rules-preview|resync|logs [file]|validate}"
        exit 1
        ;;
    esac
}

main "$@"
