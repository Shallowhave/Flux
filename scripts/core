#!/system/bin/sh

# ==============================================================================
# [ Flux Proxy Core Controller ]
# Description: Lifecycle management for the sing-box engine (start, stop, wait).
# ==============================================================================

# Strict error handling
set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

_script_path="${0}"
case "${_script_path}" in
/*) ;;
*) _script_path="${PWD}/${_script_path}" ;;
esac
readonly SCRIPT_DIR="${_script_path%/*}"

. "${SCRIPT_DIR}/lib"
. "${SCRIPT_DIR}/log"

readonly LOG_COMPONENT="Core"

# ==============================================================================
# [ Internal Helper Functions ]
# ==============================================================================

_launch_singbox() {
    ulimit -SHn 1000000 2>/dev/null
    local run_as="${CORE_USER}:${CORE_GROUP}"
    local pid

    if [ "${run_as}" != "root:root" ] && command -v busybox >/dev/null 2>&1; then
        nohup busybox setuidgid "${run_as}" \
            "${SING_BOX_BIN}" run -c "${CONFIG_FILE}" -D "${RUN_DIR}" >>"${SING_BOX_LOG}" 2>&1 &
    else
        nohup "${SING_BOX_BIN}" run -c "${CONFIG_FILE}" -D "${RUN_DIR}" >>"${SING_BOX_LOG}" 2>&1 &
    fi

    pid=$!
    if ! write_pid_file "${SING_BOX_PID_FILE}" "${pid}"; then
        kill -9 "${pid}" 2>/dev/null
        return 1
    fi
    return 0
}

_wait_for_ready() {
    local count=0
    local pid
    pid=$(read_pid_file "${SING_BOX_PID_FILE}" "sing-box") || return 1

    while [ "${count}" -lt "${CORE_TIMEOUT}" ]; do
        if [ -n "${pid}" ] && ! pid_alive "${pid}"; then
            rm -f "${SING_BOX_PID_FILE}"
            return 1
        fi

        if [ -n "${pid}" ] && ! pid_matches_cmd "${pid}" "${SING_BOX_BIN}"; then
            log_error "sing-box pid mismatch, skipping stale pid"
            rm -f "${SING_BOX_PID_FILE}"
            return 1
        fi

        if [ "${PROXY_MODE}" = "tun" ]; then
            if [ -d "/sys/class/net/${TUN_INTERFACE}" ]; then
                log_debug "Core ready on TUN ${TUN_INTERFACE}"
                return 0
            fi
        elif is_port_listening "${PROXY_PORT}"; then
            log_debug "Core ready on port ${PROXY_PORT}"
            return 0
        fi

        sleep 1
        count=$((count + 1))
    done

    _kill_core
    return 1
}

_kill_core() {
    local pid
    if pid=$(get_valid_daemon_pid "${SING_BOX_PID_FILE}" "${SING_BOX_BIN}" "Core"); then
        terminate_pid "${pid}" "${CORE_TIMEOUT}" "Core" || true
        rm -f "${SING_BOX_PID_FILE}"
    fi
    return 0
}

# ==============================================================================
# [ Public Control API ]
# ==============================================================================

start_core() {
    run -v "Launch singbox" _launch_singbox || return $?
    run -v "Core startup" _wait_for_ready || return $?
}

stop_core() {
    run -v "Kill process" _kill_core
}

# ==============================================================================
# [ Main Execution Entry ]
# ==============================================================================
main() {
    local action="${1:-}"

    case "${action}" in
    start)
        start_core
        ;;
    stop)
        stop_core
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
    esac
}

main "$@"
