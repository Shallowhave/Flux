#!/system/bin/sh

# ==============================================================================
# [ Flux Event Dispatcher ]
# Description: Inotify event handler and the single orchestration entrypoint.
#
# Runtime call graph (effective paths only):
#   boot: flux_service -> init -> (event:init_ok) -> dispatcher -> core/tproxy/addrsync
#   config write:
#     settings.ini    -> stop(all) -> init -> (event:init_ok) -> start(all)
#     config.json     -> init cache -> restart(core)
#     addrsyncd.toml  -> restart(addrsync)
#
# Invariants:
#   1) dispatcher is the only runtime orchestrator for start/stop/restart/fail transitions.
#   2) init only prepares runtime prerequisites and emits EVENT_INIT_OK.
#   3) core/tproxy/addrsync only manage component lifecycle.
#   4) failures must converge to STOPPED/FAILED without stale ready markers.
# ==============================================================================

set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

_script_path="${0}"
case "${_script_path}" in
/*) ;;
*) _script_path="${PWD}/${_script_path}" ;;
esac
readonly SCRIPT_DIR="${_script_path%/*}"

. "${SCRIPT_DIR}/lib"
. "${SCRIPT_DIR}/log"

readonly LOG_COMPONENT="Disp"

load_config || exit 1

# ==============================================================================
# [ Component Control ]
# ==============================================================================

_parallel_run() {
    local action="${1}"
    local p_core p_tproxy p_addrsync rc

    if [ "${action}" = "start" ]; then
        sh "${CORE_SCRIPT}" start </dev/null &
        p_core=$!
        sh "${ADDRSYNC_SCRIPT}" start </dev/null &
        p_addrsync=$!

        if ! wait "${p_core}"; then
            log_error "Core startup failed"
            kill -9 "${p_addrsync}" 2>/dev/null || true
            wait "${p_addrsync}" 2>/dev/null || true
            sh "${ADDRSYNC_SCRIPT}" stop </dev/null || true
            return 1
        fi

        sh "${TPROXY_SCRIPT}" start </dev/null &
        p_tproxy=$!

        rc=0
        wait "${p_tproxy}" || rc=1
        wait "${p_addrsync}" || rc=1
        return "${rc}"
    fi

    sh "${TPROXY_SCRIPT}" "${action}" </dev/null &
    p_tproxy=$!
    sh "${ADDRSYNC_SCRIPT}" "${action}" </dev/null &
    p_addrsync=$!
    sh "${CORE_SCRIPT}" "${action}" </dev/null &
    p_core=$!

    # Wait with 10s timeout and Fail-Fast
    if ! wait_pids_timeout 10 "${p_tproxy}" "${p_addrsync}" "${p_core}"; then
        log_error "Parallel execution failed or timed out, killing children..."
        kill -9 "${p_tproxy}" "${p_addrsync}" "${p_core}" 2>/dev/null
        return 1
    fi
}

_restart_debounced() {
    local token="${1}"
    local last=""

    [ ! -f "${RESTART_STAMP_FILE}" ] && return 0
    [ "$(file_age "${RESTART_STAMP_FILE}")" -ge "${RESTART_DEBOUNCE_SEC}" ] && return 0

    IFS= read -r last <"${RESTART_STAMP_FILE}" || true
    [ "${token}" != "${last}" ]
}

_write_restart_stamp() {
    local token="${1}"
    printf '%s\n' "${token}" >"${RESTART_STAMP_FILE}"
}

# ==============================================================================
# [ State Actions ]
# ==============================================================================

_state_start() {
    [ -f "${MAGISK_MOD_DIR}/disable" ] && {
        log_warn "Service disabled, ignoring start trigger"
        return 0
    }

    log_banner "STARTING FLUX"
    rm -f "${BOOT_TRIGGER}"

    if ! sh "${INIT_SCRIPT}" init; then
        log_error "Init failed"
        _state_fail
        return 1
    fi

    if _parallel_run start; then
        sync_prop "RUNNING"
        log_info "Flux Service is READY"
    else
        _state_fail
        return 1
    fi
}

_state_stop() {
    log_banner "STOPPING FLUX"
    _parallel_run stop || true
    sync_prop "STOPPED"
    log_info "Flux Service stopped"
    return 0
}

_state_restart() {
    local changed="${1}"
    local force="${2:-0}"

    if [ "${force}" != "1" ] && ! _restart_debounced "${changed}"; then
        log_debug "Skip duplicate config event: ${changed}"
        return 0
    fi

    _write_restart_stamp "${changed}"
    log_info "Config update: ${changed}, full restart"

    log_banner "RESTARTING FLUX"

    _parallel_run stop || true

    rm -f "${EVENT_CACHE_OK}"

    if ! sh "${INIT_SCRIPT}" init; then
        log_error "Init failed"
        _state_fail
        return 1
    fi

    if _parallel_run start; then
        sync_prop "RUNNING"
        log_info "Flux Service is READY"
    else
        _state_fail
        return 1
    fi
}

_state_fail() {
    log_warn "Rolling back..."
    _parallel_run stop || true
    sync_prop "FAILED"
    return 0
}

# ==============================================================================
# [ Event Dispatch ]
# ==============================================================================

_dispatch_event() {
    local event_name="${1}"
    local event_type="${2}"
    local key="${event_name}:${event_type}"
    local action=""

    case "${key}" in
    boot_trigger:n) action="_state_start" ;;
    disable:d) action="_state_start" ;;
    disable:n) action="_state_stop" ;;
    settings.ini:y | addrsyncd.toml:y | config.json:y) action="_state_restart" ;;
    esac

    if [ -z "${action}" ]; then
        log_debug "No handler for: ${key}"
        return 0
    fi

    log_debug "Dispatching: ${key} -> ${action}"
    if ! "${action}" "${event_name}"; then
        log_error "Handler failed: ${action} (${key})"
        return 1
    fi
    return 0
}

_queue_pending_event() {
    local event_name="${1}"
    local event_type="${2}"
    atomic_write "${DISPATCH_PENDING_FILE}" printf '%s\n%s\n' "${event_type}" "${event_name}"
}

_drain_pending_events() {
    local spins=0
    local pending_type pending_name

    while [ -f "${DISPATCH_PENDING_FILE}" ] && [ "${spins}" -lt 8 ]; do
        pending_type=""
        pending_name=""

        {
            IFS= read -r pending_type || exit 1
            IFS= read -r pending_name || true
        } <"${DISPATCH_PENDING_FILE}" || break
        rm -f "${DISPATCH_PENDING_FILE}"

        [ -n "${pending_type}" ] || break
        [ -n "${pending_name}" ] || pending_name="manual"

        log_debug "Replaying pending event: ${pending_name}:${pending_type}"
        _dispatch_event "${pending_name}" "${pending_type}" || return 1

        spins=$((spins + 1))
    done

    if [ -f "${DISPATCH_PENDING_FILE}" ]; then
        log_warn "Pending event queue still busy after replay limit"
    fi
    return 0
}

_with_dispatch_lock() {
    [ -d "${RUN_DIR}" ] || mkdir -p "${RUN_DIR}" 2>/dev/null || true

    if ! mkdir "${DISPATCH_LOCK_DIR}" 2>/dev/null; then
        if [ "$#" -ge 3 ] && [ "${1}" = "_dispatch_event" ]; then
            _queue_pending_event "${2}" "${3}" || true
            log_debug "Dispatcher busy, queued overlapping event"
        else
            log_debug "Dispatcher busy, skip overlapping command"
        fi
        return 0
    fi

    local rc=0
    trap 'rmdir "${DISPATCH_LOCK_DIR}" 2>/dev/null || true' EXIT INT TERM

    "$@" || rc=$?
    [ "${rc}" -eq 0 ] && _drain_pending_events || true

    rmdir "${DISPATCH_LOCK_DIR}" 2>/dev/null || true
    trap - EXIT INT TERM

    return "${rc}"
}

main() {
    [ ! -t 2 ] && [ -n "${FLUX_LOG}" ] && exec 2>>"${FLUX_LOG}"

    local event_type="${1:-}"
    local watched_path="${2:-}"
    local event_name="${3:-${watched_path##*/}}"

    case "${event_type}" in
    start)
        _with_dispatch_lock _state_start
        return $?
        ;;
    stop)
        _with_dispatch_lock _state_stop
        return $?
        ;;
    restart)
        _with_dispatch_lock _state_restart "${2:-manual}" 1
        return $?
        ;;
    esac

    [ -n "${3:-}" ] && watched_path="${watched_path}/${event_name}"

    log_debug "Event: ${watched_path} -> ${event_type}"
    _with_dispatch_lock _dispatch_event "${event_name}" "${event_type}"
}

main "$@"
