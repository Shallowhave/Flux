#!/system/bin/sh

# ==============================================================================
# [ Flux TProxy & Routing Manager ]
# Description: Atomic iptables-restore application and PBR routing management.
# ==============================================================================

set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

_script_path="${0}"
case "${_script_path}" in
/*) ;;
*) _script_path="${PWD}/${_script_path}" ;;
esac
readonly SCRIPT_DIR="${_script_path%/*}"

. "${SCRIPT_DIR}/lib"
. "${SCRIPT_DIR}/log"

readonly LOG_COMPONENT="Tprx"

# ==============================================================================
# [ Core Operations ]
# ==============================================================================

_rules_file() {
    local action="${1}"
    local family="${2}"

    if [ "${action}" = "apply" ]; then
        [ "${family}" = "6" ] && printf '%s\n' "${CACHE_RULES_V6_FILE}" || printf '%s\n' "${CACHE_RULES_V4_FILE}"
        return 0
    fi

    if [ "${family}" = "6" ]; then
        [ -s "${ACTIVE_CLEANUP_V6_FILE}" ] && printf '%s\n' "${ACTIVE_CLEANUP_V6_FILE}" || printf '%s\n' "${CACHE_CLEANUP_V6_FILE}"
    else
        [ -s "${ACTIVE_CLEANUP_V4_FILE}" ] && printf '%s\n' "${ACTIVE_CLEANUP_V4_FILE}" || printf '%s\n' "${CACHE_CLEANUP_V4_FILE}"
    fi
}

_active_runtime_value() {
    local key="${1}"
    local default="${2:-}"
    local line

    [ -r "${ACTIVE_RUNTIME_FILE}" ] || {
        printf '%s\n' "${default}"
        return 0
    }

    while IFS= read -r line; do
        case "${line}" in
        "${key}="*)
            printf '%s\n' "${line#*=}"
            return 0
            ;;
        esac
    done <"${ACTIVE_RUNTIME_FILE}"

    printf '%s\n' "${default}"
}

_read_file_value() {
    local file="${1}"
    local default="${2:-}"
    local value=""

    [ -r "${file}" ] && IFS= read -r value <"${file}" || value="${default}"
    printf '%s\n' "${value}"
}

_write_file_value() {
    local file="${1}"
    local value="${2}"

    [ -w "${file}" ] || return 1
    printf '%s\n' "${value}" >"${file}" 2>/dev/null
}

_snapshot_active_runtime() {
    local families="${1}"
    local tmp="${ACTIVE_RUNTIME_FILE}.tmp"
    local v4_hash="" v6_hash=""
    local private_dns_mode=""

    command -v sha256sum >/dev/null 2>&1 && {
        [ -s "${ACTIVE_CLEANUP_V4_FILE}" ] && v4_hash=$(sha256sum "${ACTIVE_CLEANUP_V4_FILE}" 2>/dev/null | awk '{print $1}')
        [ -s "${ACTIVE_CLEANUP_V6_FILE}" ] && v6_hash=$(sha256sum "${ACTIVE_CLEANUP_V6_FILE}" 2>/dev/null | awk '{print $1}')
    }
    command -v settings >/dev/null 2>&1 && private_dns_mode=$(settings get global private_dns_mode 2>/dev/null || true)

    {
        printf 'FAMILIES=%s\n' "${families}"
        printf 'RULE_BACKEND=%s\n' "${RULE_BACKEND}"
        printf 'BYPASS_SET_BACKEND=%s\n' "${BYPASS_SET_BACKEND}"
        printf 'PROXY_MODE=%s\n' "${PROXY_MODE}"
        printf 'ROUTE_MANAGER=addrsyncd_pbr\n'
        printf 'TABLE_ID=%s\n' "${TABLE_ID}"
        printf 'RULE_PREF=%s\n' "${TABLE_ID}"
        printf 'IPV4_MARK=%s\n' "${IPV4_MARK}"
        printf 'IPV6_MARK=%s\n' "${IPV6_MARK}"
        printf 'BYPASS_MARK=%s\n' "${BYPASS_MARK}"
        printf 'MARK_MASK=%s\n' "${MARK_MASK}"
        printf 'PROXY_IPV6=%s\n' "${PROXY_IPV6}"
        printf 'PERFORMANCE_MODE=%s\n' "${PERFORMANCE_MODE}"
        printf 'BLOCK_QUIC=%s\n' "${BLOCK_QUIC}"
        printf 'PRIVATE_DNS_GUARD=%s\n' "${PRIVATE_DNS_GUARD}"
        printf 'IPV6_FORCE_DISABLE=%s\n' "${IPV6_FORCE_DISABLE}"
        printf 'VENDOR_FIX_PROFILE=%s\n' "${VENDOR_FIX_PROFILE}"
        printf 'HOTSPOT_FIX=%s\n' "${HOTSPOT_FIX}"
        printf 'PROXY_PORT=%s\n' "${PROXY_PORT}"
        printf 'CORE_USER=%s\n' "${CORE_USER}"
        printf 'CORE_GROUP=%s\n' "${CORE_GROUP}"
        printf 'FAKEIP_V4_RANGE=%s\n' "${FAKEIP_V4_RANGE}"
        printf 'FAKEIP_V6_RANGE=%s\n' "${FAKEIP_V6_RANGE}"
        printf 'PREV_PRIVATE_DNS_MODE=%s\n' "${private_dns_mode}"
        printf 'PREV_DISABLE_IPV6_ALL=%s\n' "$(_read_file_value /proc/sys/net/ipv6/conf/all/disable_ipv6 "")"
        printf 'PREV_DISABLE_IPV6_DEFAULT=%s\n' "$(_read_file_value /proc/sys/net/ipv6/conf/default/disable_ipv6 "")"
        printf 'PREV_IPV4_FORWARD=%s\n' "$(_read_file_value /proc/sys/net/ipv4/ip_forward "")"
        printf 'PREV_IPV6_FORWARD=%s\n' "$(_read_file_value /proc/sys/net/ipv6/conf/all/forwarding "")"
        [ -n "${v4_hash}" ] && printf 'CLEANUP_V4_SHA256=%s\n' "${v4_hash}"
        [ -n "${v6_hash}" ] && printf 'CLEANUP_V6_SHA256=%s\n' "${v6_hash}"
    } >"${tmp}" || return 1

    mv -f "${tmp}" "${ACTIVE_RUNTIME_FILE}"
}

_snapshot_active_cleanup() {
    local family="${1}"
    local src dst

    if [ "${family}" = "6" ]; then
        src="${CACHE_CLEANUP_V6_FILE}"
        dst="${ACTIVE_CLEANUP_V6_FILE}"
    else
        src="${CACHE_CLEANUP_V4_FILE}"
        dst="${ACTIVE_CLEANUP_V4_FILE}"
    fi

    [ -s "${src}" ] || {
        log_error "Cleanup cache missing: ${src}"
        return 1
    }
    cp -f "${src}" "${dst}"
}

_remove_active_cleanup() {
    local family="${1}"

    if [ "${family}" = "6" ]; then
        rm -f "${ACTIVE_CLEANUP_V6_FILE}" 2>/dev/null || true
    else
        rm -f "${ACTIVE_CLEANUP_V4_FILE}" 2>/dev/null || true
    fi
}

_snapshot_active_features() {
    rm -f "${ACTIVE_FEATURES_FILE}" 2>/dev/null || true
    {
        [ "${BLOCK_QUIC}" = "1" ] && printf '%s\n' "BLOCK_QUIC=1"
        [ "${PRIVATE_DNS_GUARD}" = "1" ] && printf '%s\n' "PRIVATE_DNS_GUARD=1"
        [ "${IPV6_FORCE_DISABLE}" = "1" ] && printf '%s\n' "IPV6_FORCE_DISABLE=1"
        [ "${HOTSPOT_FIX}" = "1" ] && printf '%s\n' "HOTSPOT_FIX=1"
        [ "${VENDOR_FIX_PROFILE}" != "none" ] && printf '%s\n' "VENDOR_FIX_PROFILE=${VENDOR_FIX_PROFILE}"
    } >"${ACTIVE_FEATURES_FILE}.tmp"
    if [ -s "${ACTIVE_FEATURES_FILE}.tmp" ]; then
        mv -f "${ACTIVE_FEATURES_FILE}.tmp" "${ACTIVE_FEATURES_FILE}"
    else
        rm -f "${ACTIVE_FEATURES_FILE}.tmp"
    fi
}

_active_feature_enabled() {
    local name="${1}"
    local line

    [ -r "${ACTIVE_FEATURES_FILE}" ] || return 1
    while IFS= read -r line; do
        [ "${line}" = "${name}=1" ] && return 0
    done <"${ACTIVE_FEATURES_FILE}"
    return 1
}

_block_quic() {
    local action="${1}"
    local family="${2}"
    local cmd="iptables"
    local chain="BLOCK_QUIC"
    [ "${family}" = "6" ] && cmd="ip6tables" && chain="BLOCK_QUIC6"

    if [ "${action}" = "apply" ]; then
        "${cmd}" -w "${IPTABLES_WAIT}" -N "${chain}" >/dev/null 2>&1 || true
        "${cmd}" -w "${IPTABLES_WAIT}" -F "${chain}" >/dev/null 2>&1 || true
        "${cmd}" -w "${IPTABLES_WAIT}" -A "${chain}" -p udp --dport 443 -j REJECT >/dev/null 2>&1 || return 1
        "${cmd}" -w "${IPTABLES_WAIT}" -D INPUT -j "${chain}" >/dev/null 2>&1 || true
        "${cmd}" -w "${IPTABLES_WAIT}" -D FORWARD -j "${chain}" >/dev/null 2>&1 || true
        "${cmd}" -w "${IPTABLES_WAIT}" -D OUTPUT -j "${chain}" >/dev/null 2>&1 || true
        "${cmd}" -w "${IPTABLES_WAIT}" -I INPUT -j "${chain}" >/dev/null 2>&1 || return 1
        "${cmd}" -w "${IPTABLES_WAIT}" -I FORWARD -j "${chain}" >/dev/null 2>&1 || return 1
        "${cmd}" -w "${IPTABLES_WAIT}" -I OUTPUT -j "${chain}" >/dev/null 2>&1 || return 1
        return 0
    fi

    while "${cmd}" -w "${IPTABLES_WAIT}" -D INPUT -j "${chain}" >/dev/null 2>&1; do :; done
    while "${cmd}" -w "${IPTABLES_WAIT}" -D FORWARD -j "${chain}" >/dev/null 2>&1; do :; done
    while "${cmd}" -w "${IPTABLES_WAIT}" -D OUTPUT -j "${chain}" >/dev/null 2>&1; do :; done
    "${cmd}" -w "${IPTABLES_WAIT}" -F "${chain}" >/dev/null 2>&1 || true
    "${cmd}" -w "${IPTABLES_WAIT}" -X "${chain}" >/dev/null 2>&1 || true
    return 0
}

_apply_compat_profiles() {
    if [ "${PRIVATE_DNS_GUARD}" = "1" ]; then
        if command -v settings >/dev/null 2>&1; then
            settings put global private_dns_mode off >/dev/null 2>&1 || log_warn "Private DNS guard failed"
        else
            log_warn "settings command missing, skip Private DNS guard"
        fi
    fi

    if [ "${IPV6_FORCE_DISABLE}" = "1" ]; then
        _write_file_value /proc/sys/net/ipv6/conf/all/disable_ipv6 1 || log_warn "Cannot disable IPv6 globally"
        _write_file_value /proc/sys/net/ipv6/conf/default/disable_ipv6 1 || true
    fi

    if [ "${HOTSPOT_FIX}" = "1" ]; then
        _write_file_value /proc/sys/net/ipv4/ip_forward 1 || log_warn "Cannot enable IPv4 forwarding"
        [ "${PROXY_IPV6}" = "1" ] && _write_file_value /proc/sys/net/ipv6/conf/all/forwarding 1 || true
    fi

    if [ "${VENDOR_FIX_PROFILE}" != "none" ]; then
        log_warn "Vendor fix profile '${VENDOR_FIX_PROFILE}' is recorded but has no generic safe action"
    fi
    return 0
}

_restore_compat_profiles() {
    local value

    if _active_feature_enabled "PRIVATE_DNS_GUARD"; then
        value="$(_active_runtime_value PREV_PRIVATE_DNS_MODE "")"
        if [ -n "${value}" ] && command -v settings >/dev/null 2>&1; then
            settings put global private_dns_mode "${value}" >/dev/null 2>&1 || true
        fi
    fi

    if _active_feature_enabled "IPV6_FORCE_DISABLE"; then
        value="$(_active_runtime_value PREV_DISABLE_IPV6_ALL "")"
        [ -n "${value}" ] && _write_file_value /proc/sys/net/ipv6/conf/all/disable_ipv6 "${value}" || true
        value="$(_active_runtime_value PREV_DISABLE_IPV6_DEFAULT "")"
        [ -n "${value}" ] && _write_file_value /proc/sys/net/ipv6/conf/default/disable_ipv6 "${value}" || true
    fi

    if _active_feature_enabled "HOTSPOT_FIX"; then
        value="$(_active_runtime_value PREV_IPV4_FORWARD "")"
        [ -n "${value}" ] && _write_file_value /proc/sys/net/ipv4/ip_forward "${value}" || true
        value="$(_active_runtime_value PREV_IPV6_FORWARD "")"
        [ -n "${value}" ] && _write_file_value /proc/sys/net/ipv6/conf/all/forwarding "${value}" || true
    fi
    return 0
}

# Manage iptables rules (apply/cleanup)
_rules() {
    local action="${1}"
    local family="${2}"
    local cmd="iptables-restore"
    [ "${family}" = "6" ] && cmd="ip6tables-restore"

    local file
    file="$(_rules_file "${action}" "${family}")"

    [ -s "${file}" ] || {
        log_error "Rule cache missing: ${file}"
        return 1
    }

    local err
    if ! err=$(command "${cmd}" -w "${IPTABLES_WAIT}" --noflush <"${file}" 2>&1); then
        log_error "${cmd} failed"
        printf '%s\n' "${err}" | while IFS= read -r l; do
            log_error "  >> ${l}"
        done
        return 1
    fi
    return 0
}

_clean_main_jumps() {
    local family="${1}"
    local cmd="iptables"
    local suffix=""
    [ "${family}" = "6" ] && cmd="ip6tables" && suffix="6"

    while "${cmd}" -w "${IPTABLES_WAIT}" -t mangle -D PREROUTING -j "PROXY_PREROUTING${suffix}" >/dev/null 2>&1; do :; done
    while "${cmd}" -w "${IPTABLES_WAIT}" -t mangle -D OUTPUT -j "PROXY_OUTPUT${suffix}" >/dev/null 2>&1; do :; done
    return 0
}

_force_cleanup_rules() {
    local family="${1}"
    local cmd="iptables"
    local suffix=""
    local loopback="127.0.0.1"
    local fake_range
    local fake_proto="icmp"
    local fake_to="127.0.0.1"
    local proxy_port core_user core_group

    fake_range="$(_active_runtime_value FAKEIP_V4_RANGE "${FAKEIP_V4_RANGE}")"
    proxy_port="$(_active_runtime_value PROXY_PORT "${PROXY_PORT}")"
    core_user="$(_active_runtime_value CORE_USER "${CORE_USER}")"
    core_group="$(_active_runtime_value CORE_GROUP "${CORE_GROUP}")"
    [ "${family}" = "6" ] && cmd="ip6tables" && suffix="6" && loopback="::1" && fake_range="$(_active_runtime_value FAKEIP_V6_RANGE "${FAKEIP_V6_RANGE}")" && fake_proto="ipv6-icmp" && fake_to="::1"

    local chains="PROXY_PREROUTING PROXY_OUTPUT BYPASS_IP APP_CHAIN ACTION_PROXY_PRE ACTION_PROXY_OUT ACTION_BYPASS BYP_Z0 BYP_Z1 BYP_Z2 BYP_Z3 BYP_Z4 BYP_Z5 BYP_Z6 BYP_Z7 BYP_Z8 BYP_Z9 BYP_Z10 BYP_Z11 BYP_Z12 BYP_Z13 BYP_Z14 BYP_Z15 DIVERT"
    local chain

    _clean_main_jumps "${family}" || true
    for chain in ${chains}; do
        "${cmd}" -w "${IPTABLES_WAIT}" -t mangle -F "${chain}${suffix}" >/dev/null 2>&1 || true
    done
    for chain in ${chains}; do
        "${cmd}" -w "${IPTABLES_WAIT}" -t mangle -X "${chain}${suffix}" >/dev/null 2>&1 || true
    done

    while "${cmd}" -w "${IPTABLES_WAIT}" -t filter -D OUTPUT -d "${loopback}" -p tcp -m owner --uid-owner "${core_user}" --gid-owner "${core_group}" -m tcp --dport "${proxy_port}" -j REJECT >/dev/null 2>&1; do :; done

    if [ "${family}" != "6" ] || [ "${KFEAT_IPV6_NAT}" = "1" ]; then
        while "${cmd}" -w "${IPTABLES_WAIT}" -t nat -D OUTPUT -d "${fake_range}" -p "${fake_proto}" -j DNAT --to-destination "${fake_to}" >/dev/null 2>&1; do :; done
        while "${cmd}" -w "${IPTABLES_WAIT}" -t nat -D PREROUTING -d "${fake_range}" -p "${fake_proto}" -j DNAT --to-destination "${fake_to}" >/dev/null 2>&1; do :; done
    fi

    while "${cmd}" -w "${IPTABLES_WAIT}" -t mangle -D POSTROUTING -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu >/dev/null 2>&1; do :; done
    return 0
}

_cleanup_rules() {
    local family="${1}"

    if _rules cleanup "${family}"; then
        _clean_main_jumps "${family}" || true
        return 0
    fi

    log_warn "IPv${family} restore cleanup failed, forcing Flux rule cleanup"
    _force_cleanup_rules "${family}"
}

# Manage policy routing (apply/cleanup)
_route() {
    local action="${1}"
    local family="${2}"
    local mark="${IPV4_MARK}"
    local mask="${MARK_MASK}"
    local table="${TABLE_ID}"
    local pref="${TABLE_ID}"
    local target="0.0.0.0/0"
    [ "${family}" = "6" ] && mark="${IPV6_MARK}" && target="::/0"

    if [ "${action}" != "apply" ]; then
        table="$(_active_runtime_value TABLE_ID "${TABLE_ID}")"
        pref="$(_active_runtime_value RULE_PREF "${table}")"
        if [ "${family}" = "6" ]; then
            mark="$(_active_runtime_value IPV6_MARK "${IPV6_MARK}")"
        else
            mark="$(_active_runtime_value IPV4_MARK "${IPV4_MARK}")"
        fi
        mask="$(_active_runtime_value MARK_MASK "${MARK_MASK}")"
    fi

    if [ -x "${ADDRSYNCD_BIN}" ]; then
        local pbr_action="${action}"
        [ "${pbr_action}" = "cleanup" ] && pbr_action="cleanup"
        "${ADDRSYNCD_BIN}" pbr "${pbr_action}" \
            --family "${family}" \
            --mark "${mark}" \
            --mask "${mask}" \
            --table "${table}" \
            --pref "${pref}" >/dev/null 2>&1 && return 0
        [ "${action}" = "apply" ] && log_warn "addrsyncd pbr failed, falling back to ip route"
    fi

    if [ "${action}" = "apply" ]; then
        _route cleanup "${family}" || true
        if [ "${family}" = "6" ]; then
            ip -6 rule add fwmark "${mark}/${mask}" table "${table}" pref "${pref}" >/dev/null 2>&1 || return 1
            ip -6 route replace local "${target}" dev lo table "${table}" >/dev/null 2>&1 || return 1
        else
            ip rule add fwmark "${mark}/${mask}" table "${table}" pref "${pref}" >/dev/null 2>&1 || return 1
            ip route replace local "${target}" dev lo table "${table}" >/dev/null 2>&1 || return 1
        fi
        return 0
    fi

    if [ "${family}" = "6" ]; then
        while ip -6 rule del fwmark "${mark}/${mask}" table "${table}" pref "${pref}" >/dev/null 2>&1; do :; done
        ip -6 route del local "${target}" dev lo table "${table}" >/dev/null 2>&1 || true
    else
        while ip rule del fwmark "${mark}/${mask}" table "${table}" pref "${pref}" >/dev/null 2>&1; do :; done
        ip route del local "${target}" dev lo table "${table}" >/dev/null 2>&1 || true
    fi
    return 0
}

# ==============================================================================
# [ Public API ]
# ==============================================================================

start_proxy() {
    local families="4"
    [ "${PROXY_IPV6}" = "1" ] && families="4 6"

    local f
    run -v "Snapshot Active Features" _snapshot_active_features || return 1
    for f in ${families}; do
        run -v "Snapshot IPv${f} Cleanup" _snapshot_active_cleanup "${f}" || return 1
    done
    run -v "Snapshot Active Runtime" _snapshot_active_runtime "${families}" || return 1
    run -v "Apply Compatibility Profiles" _apply_compat_profiles || return 1

    for f in ${families}; do
        run -v "Apply IPv${f} Rules" _rules apply "${f}" || return 1
        run -v "Apply IPv${f} Route" _route apply "${f}" || return 1
        if [ "${BLOCK_QUIC}" = "1" ]; then
            run -v "Block IPv${f} QUIC" _block_quic apply "${f}" || return 1
        fi
    done
}

stop_proxy() {
    local families
    families="$(_active_runtime_value FAMILIES "")"
    if [ -z "${families}" ]; then
        families="4"
        [ "${PROXY_IPV6}" = "1" ] && families="4 6"
    fi

    local f
    for f in ${families}; do
        _active_feature_enabled "BLOCK_QUIC" && run -v "Clean IPv${f} QUIC" _block_quic cleanup "${f}" || true
        run -v "Clean IPv${f} Rules" _cleanup_rules "${f}" || true
        run -v "Clean IPv${f} Route" _route cleanup "${f}" || true
        _remove_active_cleanup "${f}"
    done
    run -v "Restore Compatibility Profiles" _restore_compat_profiles || true
    rm -f "${ACTIVE_FEATURES_FILE}" 2>/dev/null || true
    rm -f "${ACTIVE_RUNTIME_FILE}" 2>/dev/null || true
}

# ==============================================================================
# [ Entry Point ]
# ==============================================================================

main() {
    local action="${1:-}"

    case "${action}" in
    start)
        start_proxy
        ;;
    stop)
        stop_proxy
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
    esac
}

main "$@"
