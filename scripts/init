#!/system/bin/sh

# ==============================================================================
# [ Flux Initialization Orchestrator ]
# Description: Pre-flight integrity checks, environment setup, and log rotation.
#
# Invariant:
#   init is preparation-only. It never decides service state transitions.
#   Start/stop/restart/fail orchestration belongs to dispatcher.
# ==============================================================================

set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

_script_path="${0}"
case "${_script_path}" in
/*) ;;
*) _script_path="${PWD}/${_script_path}" ;;
esac
readonly SCRIPT_DIR="${_script_path%/*}"

. "${SCRIPT_DIR}/lib"
. "${SCRIPT_DIR}/log"

readonly LOG_COMPONENT="Init"

# ==============================================================================
# [ Pre-flight Checks ]
# ==============================================================================

_check_integrity() {
    local bin

    for bin in "${SING_BOX_BIN}" "${ADDRSYNCD_BIN}" "${JQ_BIN}"; do
        [ ! -f "${bin}" ] && {
            log_error "Binary missing: ${bin##*/}"
            return 1
        }
        [ -x "${bin}" ] || chmod +x "${bin}" 2>/dev/null
        [ -x "${bin}" ] || {
            log_error "Binary not executable: ${bin##*/}"
            return 1
        }
    done

    for script in "${CORE_SCRIPT}" "${TPROXY_SCRIPT}" "${ADDRSYNC_SCRIPT}" "${UPDATE_SCRIPT}" "${FLUXCTL_SCRIPT}"; do
        [ ! -f "${script}" ] && {
            log_error "Script missing: ${script##*/}"
            return 1
        }
    done

    # NOTE: CONFIG_FILE is intentionally excluded here. It can be generated by updater.
    for conf in "${SETTINGS_FILE}" "${ADDRSYNCD_CONF_FILE}" "${TEMPLATE_FILE}"; do
        [ ! -f "${conf}" ] && {
            log_error "Config missing: ${conf##*/}"
            return 1
        }
    done
    return 0
}

# ==============================================================================
# [ Directory Initialization ]
# ==============================================================================

_init_dirs() {
    local dir

    for dir in "${RUN_DIR}" "${CACHE_DIR}"; do
        [ ! -d "${dir}" ] && mkdir -p "${dir}"
    done
    [ -d "${RUN_DIR}" ] && chmod 0755 "${RUN_DIR}"
    return 0
}

# ==============================================================================
# [ Log Maintenance ]
# ==============================================================================

_rotate_log() {
    local log sz

    for log in "${FLUX_LOG}" "${SING_BOX_LOG}" "${ADDRSYNCD_LOG_FILE}"; do
        [ ! -f "${log}" ] && continue
        sz=$(file_size "${log}")
        if [ "${sz}" -gt "${LOG_MAX_SIZE}" ]; then
            log_info "Rotating ${log##*/} (size: ${sz})"
            cp -f "${log}" "${log}.bak" || return 1
            : >"${log}" || return 1
        fi
    done
}

# ==============================================================================
# [ Cache Validation ]
# ==============================================================================

# Cache validation: rebuild if missing or invalid
_validate_cache() {
    if [ -f "${EVENT_CACHE_OK}" ]; then
        if [ -s "${CACHE_CONFIG_FILE}" ] &&
            [ -s "${CACHE_RULES_V4_FILE}" ] &&
            [ -s "${CACHE_CLEANUP_V4_FILE}" ]; then
            if [ "${PROXY_IPV6}" != "1" ] || {
                [ -s "${CACHE_RULES_V6_FILE}" ] &&
                    [ -s "${CACHE_CLEANUP_V6_FILE}" ]
            }; then
                log_info "Cache is valid"
                return 0
            fi
        fi
        log_warn "Cache marker present but cache files are incomplete, rebuilding..."
        rm -f "${EVENT_CACHE_OK}"
    fi

    . "${SCRIPT_DIR}/config"
    . "${SCRIPT_DIR}/rules"
    # Config must run first (rules depend on it)
    atomic_write "${CACHE_CONFIG_FILE}" build_config || return 1

    # Load generated config cache for deterministic rule generation (e.g. PROXY_IPV6).
    set -a
    . "${CACHE_CONFIG_FILE}"
    set +a

    awk '/^KFEAT_/ { print }' "${CACHE_CONFIG_FILE}" >"${CACHE_KERNEL_CAPS_FILE}" 2>/dev/null || true

    # Parallel rule generation for performance
    local pids=""

    atomic_write "${CACHE_RULES_V4_FILE}" generate -A "4" &
    pids="${pids} $!"
    atomic_write "${CACHE_CLEANUP_V4_FILE}" generate -D "4" &
    pids="${pids} $!"
    [ "${PROXY_IPV6}" = "1" ] && {
        atomic_write "${CACHE_RULES_V6_FILE}" generate -A "6" &
        pids="${pids} $!"
        atomic_write "${CACHE_CLEANUP_V6_FILE}" generate -D "6" &
        pids="${pids} $!"
    }

    # shellcheck disable=SC2086
    wait_pids ${pids} || return 1

    log_debug "Cache build success"
    touch "${EVENT_CACHE_OK}"
}

# ==============================================================================
# [ Update Check ]
# ==============================================================================

_check_update() {
    local need_update=0
    if [ ! -f "${CONFIG_FILE}" ]; then
        need_update=1
    elif [ "${UPDATE_INTERVAL}" = "0" ]; then
        log_debug "Auto-update disabled (UPDATE_INTERVAL=0)"
    elif [ "$(file_age "${CONFIG_FILE}")" -ge "${UPDATE_INTERVAL}" ]; then
        need_update=1
    else
        log_debug "Config up to date"
    fi

    if [ "${need_update}" = "1" ]; then
        if ! sh "${UPDATE_SCRIPT}" update; then
            log_error "Subscription update failed"
            return 1
        fi
        # Config changed, force cache rebuild in current init flow.
        rm -f "${EVENT_CACHE_OK}"
    fi

    [ -s "${CONFIG_FILE}" ] || {
        log_error "config.json is missing or empty after update check"
        return 1
    }
    return 0
}

# ==============================================================================
# [ Init Environment ]
# ==============================================================================

_init_env() {
    run "Init dirs" _init_dirs || return $?
    run "Check integrity" _check_integrity || return $?

    # Run log rotation in background to speed up startup
    (run "Rotate log" _rotate_log) &
    local pid_log=$!

    run "Check update" _check_update || return $?
    run "Validate cache" _validate_cache || return $?

    wait "${pid_log}"
    return 0
}

_rebuild_cache_only() {
    run "Init dirs" _init_dirs || return $?
    rm -f "${EVENT_CACHE_OK}"
    run "Validate cache" _validate_cache || return $?
    run "Rotate log" _rotate_log
    return 0
}

# ==============================================================================
# [ Startup Orchestration ]
# ==============================================================================

main() {
    local action="${1:-}"

    case "${action}" in
    init)
        _init_env
        ;;
    cache)
        _rebuild_cache_only
        ;;
    *)
        echo "Usage: $0 {init|cache}"
        exit 1
        ;;
    esac
}

main "$@"
